# Variaveis de ambiente opcionais
# Copie este arquivo para .env e preencha conforme necessario

# Diretorio base para resultados (padrao: results/)
RESULTS_DIR=results

# Nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Modelo Whisper a usar: tiny, base, small, medium, large
# Modelos maiores tem maior precisao mas consomem mais memoria e sao mais lentos
WHISPER_MODEL=small

# Numero maximo de frames a processar por video (0 = sem limite)
MAX_FRAMES_VIDEO=300

# FPS de processamento do video (quantos frames por segundo analisar)
FPS_PROCESSAMENTO=2
